<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<title>综合分析报告</title>
<script src="/static/echarts.min.js"></script>
<style>
  .minerva-report {
    font-family: "Noto Sans CJK SC", "Noto Sans SC", "Microsoft YaHei", "SimHei", sans-serif;
    color: #1f2329;
    line-height: 1.6;
    font-size: 14px;
    max-width: 960px;
    margin: 0 auto;
  }
  .minerva-report h1 {
    font-size: 22px;
    margin-bottom: 0.2em;
  }
  .minerva-report .report-subtitle {
    color: #909399;
    font-size: 13px;
    margin-bottom: 1.2em;
  }
  .minerva-report h2 {
    font-size: 16px;
    margin-top: 1.6em;
    border-left: 4px solid #5470c6;
    padding-left: 0.5em;
    color: #2f3542;
  }
  .minerva-report .problem-card {
    border: 1px solid #e4e7ed;
    border-radius: 6px;
    padding: 12px 16px;
    background-color: #f7f8fa;
    margin-bottom: 1em;
  }
  .minerva-report .problem-card p {
    margin: 0.3em 0;
  }
  .minerva-report .problem-card .label {
    font-weight: bold;
    margin-right: 0.4em;
    color: #606266;
  }
  .minerva-report .kpi-row {
    display: flex;
    gap: 12px;
    margin: 0.8em 0 1.2em;
    flex-wrap: wrap;
  }
  .minerva-report .kpi-card {
    flex: 1;
    min-width: 120px;
    border: 1px solid #e4e7ed;
    border-radius: 6px;
    padding: 12px 14px;
    text-align: center;
    background-color: #fff;
  }
  .minerva-report .kpi-card .kpi-value {
    font-size: 26px;
    font-weight: bold;
    color: #2f3542;
  }
  .minerva-report .kpi-card .kpi-label {
    font-size: 12px;
    color: #909399;
    margin-top: 0.2em;
  }
  .minerva-report .kpi-card.kpi-verified .kpi-value { color: #67c23a; }
  .minerva-report .kpi-card.kpi-rejected .kpi-value { color: #f56c6c; }
  .minerva-report .kpi-card.kpi-partial .kpi-value { color: #e6a23c; }
  .minerva-report .status-chart {
    height: 280px;
    margin-bottom: 1em;
  }
  .minerva-report .group-block {
    margin-bottom: 1em;
  }
  .minerva-report .group-title {
    font-weight: bold;
    font-size: 15px;
    margin-bottom: 0.4em;
  }
  .minerva-report .hypothesis-item {
    border: 1px solid #e4e7ed;
    border-radius: 6px;
    padding: 10px 14px;
    margin-bottom: 0.6em;
  }
  .minerva-report .hypothesis-item .hypothesis-label {
    font-weight: 600;
  }
  .minerva-report .badge {
    display: inline-block;
    padding: 0.1em 0.6em;
    border-radius: 0.3em;
    font-size: 12px;
    font-weight: bold;
    color: #fff;
    margin-left: 0.5em;
  }
  .minerva-report .status-verified { background-color: #67c23a; }
  .minerva-report .status-partial { background-color: #e6a23c; }
  .minerva-report .status-rejected { background-color: #f56c6c; }
  .minerva-report .status-pending,
  .minerva-report .status-verifying { background-color: #909399; }
  .minerva-report .confidence-高 { background-color: #67c23a; }
  .minerva-report .confidence-中 { background-color: #e6a23c; }
  .minerva-report .confidence-低 { background-color: #f56c6c; }
  .minerva-report .verification-summary {
    margin: 0.4em 0 0;
    color: #606266;
    font-size: 13px;
  }
  .minerva-report .hypothesis-chart {
    height: 280px;
    margin: 0.6em 0;
  }
  .minerva-report .executive-summary,
  .minerva-report .recommendation {
    margin: 0.4em 0;
  }
  .minerva-report .caveats {
    margin-top: 0.6em;
    padding: 8px 12px;
    background-color: #fdf6ec;
    border-left: 3px solid #e6a23c;
    color: #b88230;
    font-size: 13px;
  }
  .minerva-report .caveats ul {
    margin: 0.3em 0 0 0;
    padding-left: 1.2em;
  }
</style>
</head>
<body>
  <div class="minerva-report">
    <h1>综合分析报告</h1>
    {% if problem_card.analysis_goal %}
    <p class="report-subtitle">分析目标：{{ problem_card.analysis_goal }}</p>
    {% endif %}

    <h2>执行摘要</h2>
    <p class="executive-summary">{{ conclusion.executive_summary }}</p>

    {% if problem_card %}
    <h2>问题陈述</h2>
    <div class="problem-card">
      <p><span class="label">问题：</span>{{ problem_card.question }}</p>
      {% if problem_card.baseline %}<p><span class="label">基线：</span>{{ problem_card.baseline }}</p>{% endif %}
      {% if problem_card.business_meaning %}<p><span class="label">业务含义：</span>{{ problem_card.business_meaning }}</p>{% endif %}
    </div>
    {% endif %}

    <h2>验证总览</h2>
    <div class="kpi-row">
      <div class="kpi-card">
        <div class="kpi-value">{{ total_hypotheses }}</div>
        <div class="kpi-label">总假设数</div>
      </div>
      <div class="kpi-card kpi-verified">
        <div class="kpi-value">{{ status_counts.verified }}</div>
        <div class="kpi-label">已验证支持</div>
      </div>
      <div class="kpi-card kpi-rejected">
        <div class="kpi-value">{{ status_counts.rejected }}</div>
        <div class="kpi-label">已排除</div>
      </div>
      <div class="kpi-card kpi-partial">
        <div class="kpi-value">{{ status_counts.partial }}</div>
        <div class="kpi-label">部分验证</div>
      </div>
    </div>
    {% if status_chart %}
    <div id="status-chart" class="status-chart"></div>
    {% endif %}

    <h2>假设验证详情</h2>
    {% for group_name, nodes in groups.items() %}
    <div class="group-block">
      <div class="group-title">{{ group_name }}</div>
      {% for node in nodes %}
      <div class="hypothesis-item">
        <span class="hypothesis-label">{{ node.label }}</span>
        <span class="badge status-{{ node.status }}">{{ status_labels.get(node.status, node.status) }}</span>
        {% if node.confidence_level %}
        <span class="badge confidence-{{ node.confidence_level }}">置信度：{{ node.confidence_level }}</span>
        {% endif %}
        {% if node.verification_summary %}
        <p class="verification-summary">{{ node.verification_summary }}</p>
        {% endif %}
        {% if node.chart_spec %}
        <div id="chart-{{ node.id }}" class="hypothesis-chart"></div>
        {% endif %}
      </div>
      {% endfor %}
    </div>
    {% endfor %}

    <h2>行动建议</h2>
    <p class="recommendation">{{ conclusion.recommendation }}</p>

    {% if conclusion.caveats %}
    <h2>风险与局限性</h2>
    <div class="caveats">
      <ul>
        {% for caveat in conclusion.caveats %}
        <li>{{ caveat }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
  </div>

  <script>
    (function () {
      var charts = [];
      {% if status_chart %}
      charts.push({ id: "status-chart", option: {{ status_chart | tojson }} });
      {% endif %}
      {% for group_name, nodes in groups.items() %}
      {% for node in nodes %}
      {% if node.chart_spec %}
      charts.push({ id: "chart-{{ node.id }}", option: {{ node.chart_spec | tojson }} });
      {% endif %}
      {% endfor %}
      {% endfor %}
      charts.forEach(function (item) {
        var el = document.getElementById(item.id);
        if (el && window.echarts) {
          window.echarts.init(el).setOption(item.option);
        }
      });
    })();
  </script>
</body>
</html>
